set -e
. @CMAKE_CURRENT_BINARY_DIR@/setup.sh 0

OUTPUT="dsi_plugins.out"

# collection database must be within the index,
# at or above the first reference to it
mkdir "${SRCDIR}"

COLLECTION1="collection1"
# some realpath implementations don't allow for nonexistent paths
COLLECTION1_DB="${SRCDIR}/${COLLECTION1}.db"
touch "${COLLECTION1_DB}" # gets deleted during initial cleanup
COLLECTION1_PATH=$(realpath "${COLLECTION1_DB}")

COLLECTION2="collection2"
# some realpath implementations don't allow for nonexistent paths
COLLECTION2_DB="${SRCDIR}/${COLLECTION2}.db"
touch "${COLLECTION2_DB}" # gets deleted during initial cleanup
COLLECTION2_PATH=$(realpath "${COLLECTION2_DB}")

cleanup() {
    rm -f "${COLLECTION1_DB}" "${COLLECTION2_DB}"
}

cleanup_exit() {
    cleanup
    setup_cleanup
}

trap cleanup_exit EXIT

cleanup

(
    echo "# generate the source tree but don't index just yet"
    run_no_sort "${GENERATETREE} \"${SRCDIR}\""

    uuid() {
        python3 -c "import uuid; print(uuid.uuid4())" # Version 4 (random UUIDs)
    }

    UUIDS=(
        # collection1
        "$(uuid)" # 1KB
        "$(uuid)" # 1MB
        "$(uuid)" # directory/executable
        "$(uuid)" # directory/writable

        # collection2
        "$(uuid)" # .hidden
        "$(uuid)" # old_file
        "$(uuid)" # leaf_directory/leaf_file1
        "$(uuid)" # leaf_directory/leaf_file2

        # both collections
        "$(uuid)" # repeat_name
    )

    echo "# generate collection db for collection1"
    (
        echo "CREATE TABLE data(uuid TEXT, info1 TEXT);"
        echo "INSERT INTO  data VALUES ('${UUIDS[0]}', '0');"    # 1KB
        echo "INSERT INTO  data VALUES ('${UUIDS[1]}', '1');"    # 1MB
        echo "INSERT INTO  data VALUES ('${UUIDS[2]}', '2');"    # directory/executable
        echo "INSERT INTO  data VALUES ('${UUIDS[3]}', '3');"    # directory/writable
        echo "INSERT INTO  data VALUES ('${UUIDS[8]}', '4');"    # repeat_name
    ) | "${SQLITE3}" "${COLLECTION1_DB}"
    run_no_sort "${SQLITE3} \"${COLLECTION1_DB}\" \"SELECT uuid, info1 FROM data ORDER BY info1;\"" | @SED@ "s%[0-9a-f]\{8\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{12\}%<uuid>%g; s%${COLLECTION1_DB}%${COLLECTION1}.db%g;"

    echo "# generate collection db for collection2"
    (
        echo "CREATE TABLE data(uuid TEXT, info2 TEXT);"         # different column name
        echo "INSERT INTO  data VALUES ('${UUIDS[4]}', '5');"    # .hidden
        echo "INSERT INTO  data VALUES ('${UUIDS[5]}', '6');"    # leaf_directory/leaf_file1
        echo "INSERT INTO  data VALUES ('${UUIDS[6]}', '7');"    # leaf_directory/leaf_file2
        echo "INSERT INTO  data VALUES ('${UUIDS[7]}', '8');"    # old_file
        echo "INSERT INTO  data VALUES ('${UUIDS[8]}', '9');"    # repeat_name
    ) | "${SQLITE3}" "${COLLECTION2_DB}"
    run_no_sort "${SQLITE3} \"${COLLECTION2_DB}\" \"SELECT uuid, info2 FROM data ORDER BY info2;\"" | @SED@ "s%[0-9a-f]\{8\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{12\}%<uuid>%g; s%${COLLECTION2_DB}%${COLLECTION2}.db%g;"

    echo "# mark files as belonging to collections"

    # mark files as belonging to DSI collection 1
    os_setfattr "user.COL.file.collection1" "${UUIDS[0]}.${COLLECTION1_PATH}" "${SRCDIR}/1KB"
    os_setfattr "user.COL.file.collection1" "${UUIDS[1]}.${COLLECTION1_PATH}" "${SRCDIR}/1MB"
    os_setfattr "user.COL.file.collection1" "${UUIDS[2]}.${COLLECTION1_PATH}" "${SRCDIR}/directory/executable"
    os_setfattr "user.COL.file.collection1" "${UUIDS[3]}.${COLLECTION1_PATH}" "${SRCDIR}/directory/writable"
    os_setfattr "user.COL.file.collection1" "${UUIDS[8]}.${COLLECTION1_PATH}" "${SRCDIR}/repeat_name"

    # mark files as belonging to DSI collection 2
    os_setfattr "user.COL.file.collection2" "${UUIDS[4]}.${COLLECTION2_PATH}" "${SRCDIR}/.hidden"
    os_setfattr "user.COL.file.collection2" "${UUIDS[5]}.${COLLECTION2_PATH}" "${SRCDIR}/old_file"
    os_setfattr "user.COL.file.collection2" "${UUIDS[6]}.${COLLECTION2_PATH}" "${SRCDIR}/leaf_directory/leaf_file1"
    os_setfattr "user.COL.file.collection2" "${UUIDS[7]}.${COLLECTION2_PATH}" "${SRCDIR}/leaf_directory/leaf_file2"
    os_setfattr "user.COL.file.collection2" "${UUIDS[8]}.${COLLECTION2_PATH}" "${SRCDIR}/repeat_name"

    # have to mark directories as containing DSI collections
    # these uuids don't matter
    # ${SRCDIR} contains 2 collections
    os_setfattr "user.COL.file.collection1" "$(uuid).${COLLECTION1_PATH}" "${SRCDIR}"
    os_setfattr "user.COL.file.collection2" "$(uuid).${COLLECTION2_PATH}" "${SRCDIR}"
    os_setfattr "user.COL.file.collection1" "$(uuid).${COLLECTION1_PATH}" "${SRCDIR}/directory"
    os_setfattr "user.COL.file.collection2" "$(uuid).${COLLECTION2_PATH}" "${SRCDIR}/leaf_directory"

    echo

    echo "# index updated tree with DSI plugin"
    run_no_sort "${GUFI_DIR2INDEX} -x --plugin \"gufi_plugin_operations:${DSI_INDEXING_PLUGIN}\" \"${SRCDIR}\" \"${SEARCH}\"" | remove_time

    echo "# query collection1 with gufi_vt, joining externally"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT rpath(sname, sroll, name) AS fullpath, dsi_uuid(xattr_name, xattr_value) AS uuid FROM vrxpentries WHERE (dsi_collection_name(xattr_name) == '${COLLECTION1}') AND (uuid IS NOT NULL);\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "ATTACH 'file:${COLLECTION1_DB}?mode=ro' AS ${COLLECTION1};"
        echo "SELECT fullpath, info1 FROM gufi JOIN ${COLLECTION1}.data ON gufi.uuid == ${COLLECTION1}.data.uuid ORDER BY info1 ASC;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# query collection1 with gufi_vt, joining in gufi_vt"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    I=\"CREATE TABLE intermediate(fullpath TEXT, uuid TEXT);\", "
        echo "    E=\"INSERT INTO  intermediate SELECT rpath(sname, sroll, name) AS fullpath, dsi_uuid(xattr_name, xattr_value) AS uuid FROM vrxpentries WHERE (dsi_collection_name(xattr_name) == '${COLLECTION1}') AND (uuid IS NOT NULL);\", "
        echo "    K=\"CREATE TABLE aggregate(fullpath TEXT, uuid TEXT); ATTACH 'file:${COLLECTION1_DB}?mode=ro' AS ${COLLECTION1};\", "
        echo "    J=\"INSERT INTO  aggregate SELECT * FROM intermediate;\", "
        echo "    G=\"SELECT fullpath, info1 FROM aggregate JOIN ${COLLECTION1}.data ON aggregate.uuid == ${COLLECTION1}.data.uuid ORDER BY info1;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# query collection2 with gufi_vt, joining externally"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT rpath(sname, sroll, name) AS fullpath, dsi_uuid(xattr_name, xattr_value) AS uuid FROM vrxpentries WHERE (dsi_collection_name(xattr_name) == '${COLLECTION2}') AND (uuid IS NOT NULL);\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "ATTACH 'file:${COLLECTION2_DB}?mode=ro' AS ${COLLECTION2};"
        echo "SELECT fullpath, info2 FROM gufi JOIN ${COLLECTION2}.data ON gufi.uuid == ${COLLECTION2}.data.uuid ORDER BY info2 ASC;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# query collection2 with gufi_vt, joining in gufi_vt"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    I=\"CREATE TABLE intermediate(fullpath TEXT, uuid TEXT);\", "
        echo "    E=\"INSERT INTO  intermediate SELECT rpath(sname, sroll, name) AS fullpath, dsi_uuid(xattr_name, xattr_value) AS uuid FROM vrxpentries WHERE (dsi_collection_name(xattr_name) == '${COLLECTION2}') AND (uuid IS NOT NULL);\", "
        echo "    K=\"CREATE TABLE aggregate(fullpath TEXT, uuid TEXT); ATTACH 'file:${COLLECTION2_DB}?mode=ro' AS ${COLLECTION2};\", "
        echo "    J=\"INSERT INTO  aggregate SELECT * FROM intermediate;\", "
        echo "    G=\"SELECT fullpath, info2 FROM aggregate JOIN ${COLLECTION2}.data ON aggregate.uuid == ${COLLECTION2}.data.uuid ORDER BY info2;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi;"
    )
    gufi_vt "${query}" 2>&1 | replace

    XATTR_NAME="user.COL.file.collection"

    echo "# dsi_collection_name with bad xxatr names"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT dsi_collection_name(NULL), dsi_collection_name('') FROM vrxpentries;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi LIMIT 1;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# dsi_uuid with bad xattr names"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT dsi_uuid(NULL, NULL), dsi_uuid('', NULL) FROM vrxpentries;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi LIMIT 1;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# dsi_uuid with NULL xattr value"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT dsi_uuid('${XATTR_NAME}', NULL) FROM vrxpentries WHERE level() == 0;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# dsi_uuid with empty xattr value"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT dsi_uuid('${XATTR_NAME}', '') FROM vrxpentries WHERE level() == 0;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# dsi_dbpath calls"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT dsi_dbpath('${XATTR_NAME}', '00000000-0000-0000-0000-000000000000./collection/db/path'), dsi_dbpath(NULL, NULL), dsi_dbpath('', NULL) FROM vrxpentries;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi LIMIT 1;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# dsi_dbpath with NULL xattr value"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT dsi_dbpath('${XATTR_NAME}', NULL) FROM vrxpentries WHERE level() == 0;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi;"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# dsi_dbpath with empty xattr value"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT dsi_dbpath('${XATTR_NAME}', '') FROM vrxpentries WHERE level() == 0;\", "
        echo "    plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT * FROM gufi;"
    )
    gufi_vt "${query}" 2>&1 | replace
) | tee "${OUTPUT}"

@DIFF@ @CMAKE_CURRENT_BINARY_DIR@/dsi_plugins.expected "${OUTPUT}"
rm "${OUTPUT}"
