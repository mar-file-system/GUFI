set -e
. @CMAKE_CURRENT_BINARY_DIR@/setup.sh 0

OUTPUT="dsi_plugins.out"

COLLECTION1="collection1"
# some realpath implementations don't allow for nonexistent paths
COLLECTION1_DB="${COLLECTION1}.db"
touch "${COLLECTION1_DB}" # gets deleted during initial cleanup
COLLECTION1_DB=$(realpath "${COLLECTION1_DB}")

COLLECTION2="collection2"
# some realpath implementations don't allow for nonexistent paths
COLLECTION2_DB="${COLLECTION2}.db"
touch "${COLLECTION2_DB}" # gets deleted during initial cleanup
COLLECTION2_DB=$(realpath "${COLLECTION2_DB}")

cleanup() {
    rm -f "${COLLECTION1_DB}" "${COLLECTION2_DB}"
}

cleanup_exit() {
    cleanup
    setup_cleanup
}

trap cleanup_exit EXIT

cleanup

(
    uuid() {
        python3 -c "import uuid; print(uuid.uuid4())" # Version 4 (random UUIDs)
    }

    UUIDS=(
        # collection1
        "$(uuid)" # 1KB
        "$(uuid)" # 1MB
        "$(uuid)" # directory/executable
        "$(uuid)" # directory/writable

        # collection2
        "$(uuid)" # .hidden
        "$(uuid)" # old_file
        "$(uuid)" # leaf_directory/leaf_file1
        "$(uuid)" # leaf_directory/leaf_file2

        # both collections
        "$(uuid)" # repeat_name
    )

    echo "# generate collection db for collection1"
    (
        echo "CREATE TABLE data(uuid TEXT, info1 TEXT);"
        echo "INSERT INTO  data VALUES ('${UUIDS[0]}', '0');"
        echo "INSERT INTO  data VALUES ('${UUIDS[1]}', '1');"
        echo "INSERT INTO  data VALUES ('${UUIDS[2]}', '2');"
        echo "INSERT INTO  data VALUES ('${UUIDS[3]}', '3');"
        echo "INSERT INTO  data VALUES ('${UUIDS[8]}', '4');"
    ) | "${SQLITE3}" "${COLLECTION1_DB}"
    run_no_sort "${SQLITE3} \"${COLLECTION1_DB}\" \"SELECT uuid, info1 FROM data ORDER BY info1;\"" | @SED@ "s%[0-9a-f]\{8\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{12\}%<uuid>%g; s%${COLLECTION1_DB}%${COLLECTION1}.db%g;"

    echo "# generate collection db for collection2"
    (
        echo "CREATE TABLE data(uuid TEXT, info2 TEXT);" # different info column name
        echo "INSERT INTO  data VALUES ('${UUIDS[4]}', '5');"
        echo "INSERT INTO  data VALUES ('${UUIDS[5]}', '6');"
        echo "INSERT INTO  data VALUES ('${UUIDS[6]}', '7');"
        echo "INSERT INTO  data VALUES ('${UUIDS[7]}', '8');"
        echo "INSERT INTO  data VALUES ('${UUIDS[8]}', '9');"
    ) | "${SQLITE3}" "${COLLECTION2_DB}"
    run_no_sort "${SQLITE3} \"${COLLECTION2_DB}\" \"SELECT uuid, info2 FROM data ORDER BY info2;\"" | @SED@ "s%[0-9a-f]\{8\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{12\}%<uuid>%g; s%${COLLECTION2_DB}%${COLLECTION2}.db%g;"

    echo "# generate the source tree but don't index just yet"
    run_no_sort "${GENERATETREE} \"${SRCDIR}\""

    echo "# mark files as belonging to collections (two collections in one index, with one file belonging to both)"

    # mark files as belonging to DSI collection 1
    os_setfattr "user.COL.file.collection1" "${UUIDS[0]}.${COLLECTION1_DB}" "${SRCDIR}/1KB"
    os_setfattr "user.COL.file.collection1" "${UUIDS[1]}.${COLLECTION1_DB}" "${SRCDIR}/1MB"
    os_setfattr "user.COL.file.collection1" "${UUIDS[2]}.${COLLECTION1_DB}" "${SRCDIR}/directory/executable"
    os_setfattr "user.COL.file.collection1" "${UUIDS[3]}.${COLLECTION1_DB}" "${SRCDIR}/directory/writable"
    os_setfattr "user.COL.file.collection1" "${UUIDS[8]}.${COLLECTION1_DB}" "${SRCDIR}/repeat_name"

    # mark files as belonging to DSI collection 2
    os_setfattr "user.COL.file.collection2" "${UUIDS[4]}.${COLLECTION2_DB}" "${SRCDIR}/.hidden"
    os_setfattr "user.COL.file.collection2" "${UUIDS[5]}.${COLLECTION2_DB}" "${SRCDIR}/old_file"
    os_setfattr "user.COL.file.collection2" "${UUIDS[6]}.${COLLECTION2_DB}" "${SRCDIR}/leaf_directory/leaf_file1"
    os_setfattr "user.COL.file.collection2" "${UUIDS[7]}.${COLLECTION2_DB}" "${SRCDIR}/leaf_directory/leaf_file2"
    os_setfattr "user.COL.file.collection2" "${UUIDS[8]}.${COLLECTION2_DB}" "${SRCDIR}/repeat_name"

    # have to mark directories as containing DSI collections
    # these uuids don't matter
    # ${SRCDIR} contains 2 collections
    os_setfattr "user.COL.file.collection1" "$(uuid).${COLLECTION1_DB}" "${SRCDIR}"
    os_setfattr "user.COL.file.collection2" "$(uuid).${COLLECTION2_DB}" "${SRCDIR}"
    os_setfattr "user.COL.file.collection1" "$(uuid).${COLLECTION1_DB}" "${SRCDIR}/directory"
    os_setfattr "user.COL.file.collection2" "$(uuid).${COLLECTION2_DB}" "${SRCDIR}/leaf_directory"

    echo

    echo "# index updated tree with DSI plugin"
    run_no_sort "${GUFI_DIR2INDEX} -x --plugin \"gufi_plugin_operations:${DSI_INDEXING_PLUGIN}\" \"${SRCDIR}\" \"${SEARCH}\"" | remove_indexing_time

    echo "# directories with collections should have copies of the collection dbs they are associated with"
    run_sort "find \"${INDEXROOT}\" -name \"*collection*\""

    echo "# query collection1"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -x --plugin \"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\" -E \"SELECT rpath(sname, sroll, name), info1 FROM vrxpentries JOIN collection1.data ON (dsi_collection_name(xattr_name) == '${COLLECTION1}') AND (dsi_uuid(xattr_name, xattr_value) == collection1.data.uuid);\" \"${INDEXROOT}\" 2>/dev/null"

    echo "# query collection2"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -x --plugin \"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\" -E \"SELECT rpath(sname, sroll, name), info2 FROM vrxpentries JOIN collection2.data ON (dsi_collection_name(xattr_name) == '${COLLECTION2}') AND (dsi_uuid(xattr_name, xattr_value) == collection2.data.uuid);\" \"${INDEXROOT}\" 2>/dev/null"

    echo "# query collection1 with gufi_vt"
    query=$(
        echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(setup_res_col_type=\"ATTACH ':memory:' AS '${COLLECTION1}'; CREATE TABLE ${COLLECTION1}.data (uuid TEXT, info1 TEXT);\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, info1 FROM vrxpentries JOIN ${COLLECTION1}.data ON (dsi_collection_name(xattr_name) == '${COLLECTION1}') AND (dsi_uuid(xattr_name, xattr_value) == ${COLLECTION1}.data.uuid);\", plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", \"${INDEXROOT}\");"
        echo -n "SELECT * FROM gufi ORDER BY fullpath ASC;"
    )
    gufi_vt "${query}" | replace

    echo "# query collection2 with gufi_vt"
    query=$(
        echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(setup_res_col_type=\"ATTACH ':memory:' AS '${COLLECTION2}'; CREATE TABLE ${COLLECTION2}.data (uuid TEXT, info2 TEXT);\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, info2 FROM vrxpentries JOIN ${COLLECTION2}.data ON (dsi_collection_name(xattr_name) == '${COLLECTION2}') AND (dsi_uuid(xattr_name, xattr_value) == ${COLLECTION2}.data.uuid);\", plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", \"${INDEXROOT}\");"
        echo -n "SELECT * FROM gufi ORDER BY fullpath ASC;"
    )
    gufi_vt "${query}" | replace

    echo "#####################################"
    echo

    echo "# delete collection dbs"
    run_sort "find \"${INDEXROOT}\" -name \"*collection*\" -delete"

    echo "# fail due to missing collection dbs"
    run_no_sort "${GUFI_QUERY} -d \"${DELIM}\" -x --plugin \"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\" -E \"SELECT rpath(sname, sroll, name), info1 FROM vrxpentries JOIN collection1.data ON dsi_uuid(xattr_name, xattr_value) == collection1.data.uuid;\" \"${INDEXROOT}\" 2>&1 | sort | head -n 1" | @SED@ "s%${COLLECTION1_DB}%${COLLECTION1}.db%g;"

    echo "# gufi_vt fail due to missing collection dbs"
    query=$(
        echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(setup_res_col_type=\"ATTACH ':memory:' AS '${COLLECTION1}'; CREATE TABLE ${COLLECTION1}.data (uuid TEXT, info1 TEXT);\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, info1 FROM vrxpentries JOIN ${COLLECTION1}.data ON (dsi_collection_name(xattr_name) == '${COLLECTION1}') AND (dsi_uuid(xattr_name, xattr_value) == ${COLLECTION1}.data.uuid);\", plugin=\"gufi_plugin_operations:${DSI_QUERYING_PLUGIN}\", \"${INDEXROOT}\");"
        echo -n "SELECT * FROM gufi ORDER BY fullpath ASC;"
    )
    out=$(gufi_vt "${query}" 2>&1 | replace)
    echo "${out}" | head -n 4
    echo "${out}" | sort | @GREP@ "local copy" | head -n 1
) | tee "${OUTPUT}"

@DIFF@ @CMAKE_CURRENT_BINARY_DIR@/dsi_plugins.expected "${OUTPUT}"
rm "${OUTPUT}"
