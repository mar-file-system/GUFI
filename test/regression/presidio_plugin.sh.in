set -e
. @CMAKE_CURRENT_BINARY_DIR@/setup.sh 1

OUTPUT="presidio_plugin.out"

# this script requires the presidio docker containers to be running
# see contrib/CI/presidio.sh

(
    echo "# set some osstext1"
    run_no_sort "${SQLITE3} \"${INDEXROOT}/db.db\" \"UPDATE entries SET osstext1 = 'name = Gufi Devs' WHERE name == '1KB';\""
    run_no_sort "${SQLITE3} \"${INDEXROOT}/db.db\" \"UPDATE entries SET osstext1 = 'email = gufi-lanl@lanl.gov' WHERE name == '1MB';\""
    run_no_sort "${SQLITE3} \"${INDEXROOT}/db.db\" \"UPDATE entries SET osstext1 = 'phone = 0 (123) 456-7890' WHERE name == '.hidden';\""
    run_no_sort "${SQLITE3} \"${INDEXROOT}/db.db\" \"UPDATE entries SET osstext1 = 'time = 00:00 AM' WHERE name == 'old_file';\""
    run_no_sort "${SQLITE3} \"${INDEXROOT}/db.db\" \"UPDATE entries SET osstext1 = 'date = Jan 1, 1970' WHERE name == 'repeat_name';\""

    echo "# query without presidio"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" --plugin \"presidio:${PRESIDIO_QUERYING_PLUGIN}\" -E \"SELECT rpath(sname, sroll, name), osstext1 FROM vrxpentries\" \"${SEARCH}\" | @SED@ '\%.*|$%d'"

    echo "# query with presidio"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" --plugin \"presidio:${PRESIDIO_QUERYING_PLUGIN}\" -E \"SELECT rpath(sname, sroll, name), presidio_anonymize(osstext1) FROM vrxpentries;\" \"${SEARCH}\" | @SED@ '\%.*|$%d'"

    echo "# query with presidio through gufi_vt"
    query=$(
        echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("
        echo "    E=\"SELECT rpath(sname, sroll, name) AS fullpath, presidio_anonymize(osstext1) AS anonymized, (osstext1 == '') AS empty FROM vrpentries;\", "
        echo "    plugin=\"presidio:${PRESIDIO_QUERYING_PLUGIN}\", "
        echo "    \"${INDEXROOT}\");"
        echo "SELECT fullpath, anonymized FROM gufi WHERE empty == '0';"
    )
    gufi_vt "${query}" 2>&1 | replace

    echo "# query with presidio with values set by environment variables"
    run_sort "PRESIDIO_PLUGIN_ANALYZE_URL=\"127.0.0.1:5002/analyze\" PRESIDIO_PLUGIN_ANONYMIZE_URL=\"127.0.0.1:5001/anonymize\" PRESIDIO_PLUGIN_LANGUAGE=\"en\" ${GUFI_QUERY} -d \"${DELIM}\" --plugin \"presidio:${PRESIDIO_QUERYING_PLUGIN}\" -E \"SELECT rpath(sname, sroll, name), presidio_anonymize(osstext1) FROM vrxpentries;\" \"${SEARCH}\" | @SED@ '\%.*|$%d'"

    echo "# try to load presidio plugin multiple times"
    run_sort "${GUFI_QUERY} --plugin \"presidio:${PRESIDIO_QUERYING_PLUGIN}\" --plugin \"presidio:${PRESIDIO_QUERYING_PLUGIN}\""
) | tee "${OUTPUT}"

@DIFF@ @CMAKE_CURRENT_BINARY_DIR@/presidio_plugin.expected "${OUTPUT}"
rm "${OUTPUT}"
