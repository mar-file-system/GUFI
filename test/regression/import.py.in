import os
import subprocess
import unittest

import gufi_config
import gufi_tool

# not really a unit test
class TestImportingUserFacingScripts(unittest.TestCase):
    def setUp(self):
        self.path = 'prefix'

    def expect_stdout(self, tool, args):
        tool = gufi_tool.import_tool('', gufi_tool.TOOLS[tool][1])
        rc, out, err = tool.run([''] + args, gufi_tool.CONFIG_PATH,
                                subprocess.PIPE, subprocess.PIPE)
        self.assertEqual(rc, 0)
        self.assertEqual(type(out), str)
        self.assertNotEqual(out, '')     # stdout is not empty
        print()
        print(out)
        self.assertEqual(type(err), str)
        self.assertEqual(err, '')        # nothing in stderr

    def test_gufi_du(self):
        self.expect_stdout('du', [self.path])

    def test_gufi_find(self):
        self.expect_stdout('find', [self.path])

    def test_gufi_getfattr(self):
        self.expect_stdout('getfattr', ['-d', '-m', '.*', os.path.join(self.path, '1MB')])

    def test_gufi_ls(self):
        self.expect_stdout('ls', ['-al', self.path])

    def test_gufi_query(self):
        indexroot = gufi_config.Server(gufi_tool.CONFIG_PATH).indexroot
        self.expect_stdout('query.py', ['-E', 'SELECT rpath(sname, sroll, name) FROM vrpentries;', indexroot])

    def test_gufi_query_multiple_remotes(self):
        indexroot = gufi_config.Server(gufi_tool.CONFIG_PATH).indexroot
        self.expect_stdout('query_multiple_remotes',
                           ['-E', 'SELECT rpath(sname, sroll, name) FROM vrpentries;',
                            '@CMAKE_BINARY_DIR@/src/gufi_vt',
                            'ssh',
                            '--remote-cmd', '@CMAKE_CURRENT_BINARY_DIR@/ssh.fake',
                            'remote1', indexroot,
                            'remote2', indexroot])
        self.expect_stdout('query_multiple_remotes',
                           ['-E', 'SELECT rpath(sname, sroll, name) FROM vrpentries;',
                            '@CMAKE_BINARY_DIR@/src/gufi_vt',
                            'pdsh',
                            '--remote-cmd', '@CMAKE_CURRENT_BINARY_DIR@/pdsh.fake',
                            'remote1', 'remote2',
                            indexroot])

    def test_gufi_stat(self):
        self.expect_stdout('stat', [self.path])

    def test_gufi_stats(self):
        self.expect_stdout('stats', ['--recursive', 'depth', self.path])

if __name__ == '__main__':
    unittest.main()
