# Walk without returning results
$ gufi_query.py

# Get only directories
$ gufi_query.py -d " " -n 2 -S "SELECT name FROM vrsummary;" "prefix"
directory
empty_directory
leaf_directory
prefix
subdirectory
unusual#? directory ,

# Get only non-directories
$ gufi_query.py -d " " -n 2 -E "SELECT name FROM vrpentries;" "prefix"
.hidden
