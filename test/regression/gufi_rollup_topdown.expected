# compare find and gufi_query
$ diff <(find "prefix" | sort) <(gufi_query -n 2 -S "SELECT rpath(sname, sroll) FROM vrsummary;" -E "SELECT rpath(sname, sroll, name) FROM vrpentries;" "prefix" | sed "s%search/%%g"| sort)

# remove rollup tree and index
$ rm -rf "prefix" "search"

# generate new source tree
$ generatetree "prefix"

# index source tree
$ gufi_dir2index -x -n 2 "prefix" "search"
Creating GUFI tree search with 2 threads
Total Dirs:          6
Total Non-Dirs:      14

# generate treesummaries
$ gufi_treesummary_all -n 2 "search"

# check summary tables
$ gufi_query -x -d "|" -n 2 -S "SELECT level(), rpath(sname, sroll), canrollup, isrolledup, xattr_name, xattr_value FROM vrxsummary;" "prefix"
0|prefix|1|0||
1|prefix/directory|1|0||
1|prefix/empty_directory|1|0||
1|prefix/leaf_directory|1|0|user.name|leaf
1|prefix/leaf_directory|1|0|user.type|dir
1|prefix/unusual#? directory ,|1|0||
2|prefix/directory/subdirectory|1|0|user.name|sub
2|prefix/directory/subdirectory|1|0|user.type|dir

