# gufi_query should traverse down to level 1
$ gufi_query -x -d "|" -n 2 -S "SELECT level(), rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;" "prefix"
0|prefix|1|0
1|prefix/directory/subdirectory|1|1
1|prefix/directory|1|1
1|prefix/empty_directory|1|1
1|prefix/leaf_directory|1|1
1|prefix/unusual#? directory ,|1|1

