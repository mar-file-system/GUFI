$ gufi_rollup_topdown --help
usage: gufi_rollup_topdown [options] GUFI_tree ...
options:
  -h, --help                        help
  -H, --debug                       show assigned input values (debugging)
  -v, --version                     version
  -n, --threads <n>                 number of threads
      --min-level <n>               minimum level to go down
      --limit <count>               Highest number of files/links in a directory allowed to be rolled up
      --dry-run                     Dry run

GUFI_tree         GUFI tree to roll up


$ gufi_dir2index -n 2 "prefix" "search"
Creating GUFI tree search with 2 threads
Total Dirs:          69
Total Non-Dirs:      96

# run gufi_treesummary_all to get whether or not directories can rollup
$ gufi_treesummary_all -n 2 "prefix"

# Level 0 cannot roll up
$ gufi_query -d "|" -n 2 --min-level 0 --max-level 0 -S "SELECT rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;" "prefix"
prefix|0|0

# Level 1 should only have 1 directory that can roll up
$ gufi_query -d "|" -n 2 --min-level 1 --max-level 1 -S "SELECT rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;" "prefix"
prefix/o+rx|0|0
prefix/ugo|1|0
prefix/ug|0|0
prefix/u|0|0

# Level 2 can completely roll up
$ gufi_query -d "|" -n 2 --min-level 2 --max-level 2 -S "SELECT rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;" "prefix"
