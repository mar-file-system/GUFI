# directories should be marked canrollup = 1, isrolledup = 0
$ gufi_query -x -d "|" -n 2 -S "SELECT level(), rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;" "prefix"
0|prefix|1|0
1|prefix/directory|1|0
1|prefix/empty_directory|1|0
