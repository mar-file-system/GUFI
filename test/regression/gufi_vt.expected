# Query with WHERE size < 10
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_pentries('prefix', 2) WHERE size < 10 ORDER BY name ASC, size ASC;"
) | sqlite3
directory_symlink|4|4
executable|1|1
file_symlink|9|9
old_file|0|0
readonly|2|2
repeat_name|5|5
writable|3|3

# Query with WHERE size > 10
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_pentries('prefix', 2) WHERE size > 10 ORDER BY name ASC, size ASC;"
) | sqlite3
1KB|1024|1024
1MB|1048576|1048576
leaf_file1|11|11
leaf_file2|12|12
repeat_name|14|14
unusual, name?#|15|15

# Query entries in directory where name == 'directory'
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_pentries('prefix', 2, NULL, NULL, NULL, 'SELECT NULL FROM summary WHERE name == ''directory'';') ORDER BY name ASC, size ASC;"
) | sqlite3

executable|1|1
readonly|2|2
writable|3|3

# Query directories that contain entries larger than 1024 (only 1: prefix)
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_pentries('prefix', 2, NULL, NULL, NULL, 'SELECT NULL FROM summary WHERE maxsize > 1024;') ORDER BY name ASC, size ASC;"
) | sqlite3

.hidden|10|10
1KB|1024|1024
1MB|1048576|1048576
file_symlink|9|9
old_file|0|0
repeat_name|14|14

