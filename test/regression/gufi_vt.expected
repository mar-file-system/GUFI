# Query summary
(
.load src/gufi_vt
CREATE VIRTUAL TABLE summary USING gufi_vt_summary(prefix, 2);
SELECT name, size, mtime FROM summary ORDER BY name ASC;
) | sqlite3

directory|7|7
empty_directory|8|8
leaf_directory|13|13
prefix|17|17
subdirectory|6|6
unusual#? directory ,|16|16

