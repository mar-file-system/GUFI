# Make sure all types work
$ (
    echo ".load gufi_vt"
    echo "SELECT 1, 1.0, 'text', CAST('blob' AS BLOB), NULL FROM gufi_vt_pentries('prefix', 2) LIMIT 1;"
) | sqlite3
1|1.0|text|blob|

# Missing indexroot (error)
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_pentries();"
) | sqlite3
Parse error near line 2: no query solution

# Empty string thread count (error)
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_pentries('prefix', '') ORDER BY name ASC, size ASC;"
) | sqlite3
Runtime error near line 2: Bad thread count: '' (19)

# Zero thread count (error)
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_pentries('prefix', 0) ORDER BY name ASC, size ASC;"
) | sqlite3
Runtime error near line 2: Bad thread count: '0' (19)

