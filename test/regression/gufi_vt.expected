$ (
    echo ".load gufi_vt"
    echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("prefix", E="SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;", path_list="path_list", remote_cmd="ssh", remote_arg="remote");SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
) | sqlite3
