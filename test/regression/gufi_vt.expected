# Remote gufi_vt with min_level = 1
$ (
    echo ".load gufi_vt"
    echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("prefix", E="SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;", VERBOSE=1, min_level=1, remote_cmd="ssh", remote_arg="remote");SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
) | sqlite3
Each line is one argv[i]:
    ssh \
        remote \
        gufi_query --print-tlv -x --threads 1 --min-level "1" -E "SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;" prefix
