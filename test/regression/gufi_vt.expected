# Generate treesummary tables in all directories
$ gufi_treesummary_all "prefix"

# Query treesummary
$ (
    echo ".load gufi_vt"
    echo "SELECT minsize, maxsize, minmtime, maxmtime FROM gufi_vt_treesummary('prefix', 2) ORDER BY minsize ASC, maxsize ASC;"
) | sqlite3






-1|0|-1|0
0|1048576|0|1048576
1|5|1|5
5|5|4|5
11|12|11|12
15|15|15|15

# Query summary
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_summary('prefix', 2) ORDER BY name ASC, size ASC;"
) | sqlite3
directory|7|7
empty_directory|8|8
leaf_directory|13|13
prefix|17|17
subdirectory|6|6
unusual#? directory ,|16|16

# Query entries
$ (
    echo ".load gufi_vt"
    echo "SELECT name, size, mtime FROM gufi_vt_entries('prefix', 2) ORDER BY name ASC, size ASC;"
) | sqlite3
.hidden|10|10
1KB|1024|1024
1MB|1048576|1048576
directory_symlink|4|4
executable|1|1
file_symlink|9|9
leaf_file1|11|11
leaf_file2|12|12
old_file|0|0
readonly|2|2
repeat_name|5|5
repeat_name|14|14
unusual, name?#|15|15
writable|3|3

