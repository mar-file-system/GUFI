# Multiple indexes
$ (
    echo ".load gufi_vt"
    echo "CREATE VIRTUAL TABLE gufi USING gufi_vt("prefix/directory", E="SELECT name, size, atime, mtime FROM pentries;", 'prefix/leaf_directory', index="prefix/directory/subdirectory", threads=2, n=2);SELECT size, atime, mtime, name FROM gufi ORDER BY size ASC, name ASC;"
) | sqlite3
