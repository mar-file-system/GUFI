# Generate treesummary tables in all directories
$ gufi_treesummary_all "prefix"

# Query treesummary
$ gufi_vt_py "SELECT minsize, maxsize, minmtime, maxmtime FROM gufi_vt_treesummary('prefix', 2) ORDER BY minsize ASC, maxsize ASC;"
SQL: SELECT minsize, maxsize, minmtime, maxmtime FROM gufi_vt_treesummary('prefix', 2) ORDER BY minsize ASC, maxsize ASC;
0|1048576|0|1048576
1|5|1|5
5|5|4|5
11|12|11|12
15|15|15|15
9223372036854775807|-9223372036854775808|9223372036854775807|-9223372036854775808

# Query summary
$ gufi_vt_py "SELECT name, size, modetotxt(mode), strftime('%a %b %d %H:%M:%S UTC %Y', mtime) FROM gufi_vt_summary('prefix') ORDER BY name ASC, size ASC;"
SQL: SELECT name, size, modetotxt(mode), strftime('%a %b %d %H:%M:%S UTC %Y', mtime) FROM gufi_vt_summary('prefix') ORDER BY name ASC, size ASC;
directory|7|drwxrwxr-x|Thu Jan 01 00:00:07 UTC 1970
empty_directory|8|drwxrwxr-x|Thu Jan 01 00:00:08 UTC 1970
leaf_directory|13|drwxrwxr-x|Thu Jan 01 00:00:13 UTC 1970
prefix|17|drwxrwxr-x|Thu Jan 01 00:00:17 UTC 1970
subdirectory|6|drwxrwxr-x|Thu Jan 01 00:00:06 UTC 1970
unusual#? directory ,|16|drwxrwxr-x|Thu Jan 01 00:00:16 UTC 1970

