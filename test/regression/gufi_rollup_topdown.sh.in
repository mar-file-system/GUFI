set -e
. @CMAKE_CURRENT_BINARY_DIR@/rollup_tree.sh

OUTPUT="gufi_rollup_topdown.out"

cleanup() {
    rollup_tree_cleanup
}

cleanup_exit() {
    cleanup
    setup_cleanup
}

trap cleanup_exit EXIT

cleanup

(
run_no_sort "${GUFI_ROLLUP_TOPDOWN} --help"

run_no_sort "${GUFI_DIR2INDEX} -n ${THREADS} \"${SRCDIR}\" \"${SEARCH}\""

echo "# run gufi_treesummary_all to get whether or not directories can rollup"
run_no_sort "${GUFI_TREESUMMARY_ALL} -n ${THREADS} \"${INDEXROOT}\""

echo "# Level 0 cannot roll up"
run_sort "${GUFI_QUERY} -d \"${DELIM}\" -n ${THREADS} --min-level 0 --max-level 0 -S \"SELECT rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

echo "# Level 1 should only have 1 directory that can roll up"
run_sort "${GUFI_QUERY} -d \"${DELIM}\" -n ${THREADS} --min-level 1 --max-level 1 -S \"SELECT rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

echo "# Level 2 can completely roll up"
run_sort "${GUFI_QUERY} -d \"${DELIM}\" -n ${THREADS} --min-level 2 --max-level 2 -S \"SELECT rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

echo "# Level 3 can completely roll up"
run_sort "${GUFI_QUERY} -d \"${DELIM}\" -n ${THREADS} --min-level 3 --max-level 3 -S \"SELECT rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

orig=$(run_sort "${GUFI_QUERY} -d \" \" -n ${THREADS} -S \"SELECT rpath(sname, sroll), canrollup FROM vrsummary;\" -E \"SELECT rpath(sname, sroll, name) FROM vrpentries;\" \"${INDEXROOT}\"")
echo "${orig}"

echo "# do rollup"
run_no_sort "${GUFI_ROLLUP_TOPDOWN} -n ${THREADS} \"${INDEXROOT}\""

echo "# query should return same data"
new=$(run_sort "${GUFI_QUERY} -d \" \" -n ${THREADS} -S \"SELECT rpath(sname, sroll), canrollup FROM vrsummary;\" -E \"SELECT rpath(sname, sroll, name) FROM vrpentries;\" \"${INDEXROOT}\"")
echo "${new}"

echo "# compare old and new output"
echo "$ @DIFF@ <(original) <(new)" | replace
@DIFF@ <(echo -e "${orig}") <(echo -e "${new}")
echo

echo "# see which directories are walked when querying"
echo "# ugo stops because it was rolled up"
echo "# dir* directories were all rolled up"
run_sort "${GUFI_QUERY} -d \"${DELIM}\" -n ${THREADS} -S \"SELECT rpath(sname, sroll) FROM vrsummary WHERE isroot == 1;\" \"${INDEXROOT}\""

echo "# compare find and gufi_query"
run_no_sort "@DIFF@ <(find \"${SRCDIR}\" | sort) <(${GUFI_QUERY} -n ${THREADS} -S \"SELECT rpath(sname, sroll) FROM vrsummary;\" -E \"SELECT rpath(sname, sroll, name) FROM vrpentries;\" \"${INDEXROOT}\" | @SED@ \"s%${SEARCH}/%%g\"| sort)"

echo "# remove rollup tree and index"
run_no_sort "rm -rf \"${SRCDIR}\" \"${SEARCH}\""

echo "# generate new source tree"
run_no_sort "${GENERATETREE} \"${SRCDIR}\""

echo "# index source tree"
run_no_sort "${GUFI_DIR2INDEX} -x -n ${THREADS} \"${SRCDIR}\" \"${SEARCH}\""

echo "# generate treesummaries"
run_no_sort "${GUFI_TREESUMMARY_ALL} -n ${THREADS} \"${SEARCH}\""

echo "# check summary tables"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -S \"SELECT level(), rpath(sname, sroll), canrollup, isrolledup, xattr_name, xattr_value FROM vrxsummary;\" \"${INDEXROOT}\""

echo "# check entries tables"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -E \"SELECT level(), rpath(sname, sroll, name), xattr_name, xattr_value FROM vrxpentries;\" \"${INDEXROOT}\""

echo "# do a dry run"
run_no_sort "${GUFI_ROLLUP_TOPDOWN} -n ${THREADS} --dry-run \"${SEARCH}\""

echo "# index should not have been rolled up"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -S \"SELECT level(), rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

echo "# roll up index"
run_no_sort "${GUFI_ROLLUP_TOPDOWN} -n ${THREADS} \"${SEARCH}\""

echo "# check rolled up summary tables"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -S \"SELECT level(), rpath(sname, sroll), canrollup, isrolledup, xattr_name, xattr_value FROM vrxsummary;\" \"${INDEXROOT}\""

echo "# check rolled up entries tables"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -E \"SELECT level(), rpath(sname, sroll, name), xattr_name, xattr_value FROM vrxpentries;\" \"${INDEXROOT}\""

echo "# remove rollup data"
run_no_sort "${GUFI_UNROLLUP} -n ${THREADS} \"${SEARCH}\""

echo "# directories should be marked canrollup = 1, isrolledup = 0"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -S \"SELECT level(), rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

echo "# roll up starting at level 1"
run_no_sort "${GUFI_ROLLUP_TOPDOWN} -n ${THREADS} --min-level 1 \"${INDEXROOT}\""

echo "# gufi_query should traverse down to level 1"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -S \"SELECT level(), rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

echo "# remove rollup data"
run_no_sort "${GUFI_UNROLLUP} -n ${THREADS} \"${SEARCH}\""

echo "# roll up with limit of 5 files"
run_no_sort "${GUFI_ROLLUP_TOPDOWN} -n ${THREADS} --limit 5 \"${SEARCH}\""

echo "# all subdirectories rolled up, but did not roll up into ${INDEXROOT}"
run_sort "${GUFI_QUERY} -x -d \"${DELIM}\" -n ${THREADS} -S \"SELECT level(), rpath(sname, sroll), canrollup, isrolledup FROM vrsummary;\" \"${INDEXROOT}\""

echo "# bad thread count"
run_no_sort "${GUFI_ROLLUP_TOPDOWN} -n 18446744073709551615 \"${SEARCH}\""
) | remove_time | @SED@ '\%Time to do%d; \%Min: .*s$%d; \%Max: .*s$%d; \%Mean: .*s$%d; \%Stdev: .*s$%d;' | tee "${OUTPUT}"

@DIFF@ @CMAKE_CURRENT_BINARY_DIR@/gufi_rollup_topdown.expected "${OUTPUT}"
rm "${OUTPUT}"
