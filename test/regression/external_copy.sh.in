# OF SUCH DAMAGE.



set -e
. @CMAKE_CURRENT_BINARY_DIR@/setup.sh 1

OUTPUT="external_copy.out"

(
    TABLE="tab"

    EXTDB_PATH="${INDEXROOT}/ext1.db"
    (
        echo "CREATE TABLE ${TABLE}(data TEXT, inode TEXT);"
        echo "INSERT INTO tab VALUES ('data00', '0');"
        echo "INSERT INTO tab VALUES ('data01', '10');"
        echo "INSERT INTO tab VALUES ('data02', '14');"
        echo "INSERT INTO tab VALUES ('data03', '1024');"
        echo "INSERT INTO tab VALUES ('data04', '1048576');"
    ) | "${SQLITE3}" "${EXTDB_PATH}"
    echo "# Add external database ${EXTDB_PATH}"
    run_no_sort "${SQLITE3} \"${EXTDB_PATH}\" \"SELECT * FROM ${TABLE};\""

    EXTDB_PATH="${INDEXROOT}/directory/ext1.db"
    (
        echo "CREATE TABLE ${TABLE}(data TEXT, inode TEXT);"
        echo "INSERT INTO tab VALUES ('data05', '1');"
        echo "INSERT INTO tab VALUES ('data06', '2');"
        echo "INSERT INTO tab VALUES ('data07', '3');"
    ) | "${SQLITE3}" "${EXTDB_PATH}"
    echo "# Add external databases to ${EXTDB_PATH}"
    run_no_sort "${SQLITE3} \"${EXTDB_PATH}\" \"SELECT * FROM ${TABLE};\""

    EXTDB_PATH="${INDEXROOT}/directory/subdirectory/ext2.db"
    (
        echo "CREATE TABLE ${TABLE}(data TEXT, inode TEXT);"
        echo "INSERT INTO tab VALUES ('data08', '4');"
        echo "INSERT INTO tab VALUES ('data09', '5');"
    ) | "${SQLITE3}" "${EXTDB_PATH}"
    echo "# Add external database ${EXTDB_PATH}"
    run_no_sort "${SQLITE3} \"${EXTDB_PATH}\" \"SELECT * FROM ${TABLE};\""

    EXTDB_PATH="${INDEXROOT}/leaf_directory/ext2.db"
    (
        echo "CREATE TABLE ${TABLE}(data TEXT, inode TEXT);"
        echo "INSERT INTO tab VALUES ('data10', '11');"
        echo "INSERT INTO tab VALUES ('data11', '12');"
    ) | "${SQLITE3}" "${EXTDB_PATH}"
    echo "# Add external database ${EXTDB_PATH}"
    run_no_sort "${SQLITE3} \"${EXTDB_PATH}\" \"SELECT * FROM ${TABLE};\""

    # reset inode of directory/subdirectory/repeat_name
    "${SQLITE3}" "${INDEXROOT}/directory/subdirectory/db.db" "UPDATE entries SET inode = CAST(mtime AS TEXT);"

    # name of table where copied data lands
    COPY_NAME="ext"

    echo "# Copy ext1.db"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}(data TEXT, inode TEXT);\" --external-copy \"ext1\\.db\" \"INSERT INTO ${COPY_NAME} SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME} ON vrpentries.inode == ${COPY_NAME}.inode; DELETE FROM ${COPY_NAME};\" \"${INDEXROOT}\""

    echo "# Copy ext2.db"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}(data TEXT, inode TEXT);\" --external-copy \"ext2\\.db\" \"INSERT INTO ${COPY_NAME} SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME} ON vrpentries.inode == ${COPY_NAME}.inode; DELETE FROM ${COPY_NAME};\" \"${INDEXROOT}\""

    echo "# Copy both ext1.db and ext2.db with one pattern"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}(data TEXT, inode TEXT);\" --external-copy \"ext.*\\.db\" \"INSERT INTO ${COPY_NAME} SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME} ON vrpentries.inode == ${COPY_NAME}.inode; DELETE FROM ${COPY_NAME};\" \"${INDEXROOT}\""

    echo "# Copy both ext1.db and ext2.db with separate patterns into one table"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}(data TEXT, inode TEXT);\" --external-copy \"ext1\\.db\" \"INSERT INTO ${COPY_NAME} SELECT * FROM ${TABLE};\" --external-copy \"ext2\\.db\" \"INSERT INTO ${COPY_NAME} SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME} ON vrpentries.inode == ${COPY_NAME}.inode; DELETE FROM ${COPY_NAME};\" \"${INDEXROOT}\""

    echo "# Copy both ext1.db and ext2.db with one pattern into two tables but only select from one of them"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}1(data TEXT, inode TEXT); CREATE TABLE ${COPY_NAME}2(data TEXT, inode TEXT);\" --external-copy \"ext.*\\.db\" \"INSERT INTO ${COPY_NAME}1 SELECT * FROM ${TABLE}; INSERT INTO ${COPY_NAME}2 SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME}1 ON vrpentries.inode == ${COPY_NAME}1.inode; DELETE FROM ${COPY_NAME}1; DELETE FROM ${COPY_NAME}2;\" \"${INDEXROOT}\""

    echo "# Multiple matches on the same basename"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}1(data TEXT, inode TEXT); CREATE TABLE ${COPY_NAME}2(data TEXT, inode TEXT);\" --external-copy \"1\\.db\" \"INSERT INTO ${COPY_NAME}1 SELECT * FROM ${TABLE};\" --external-copy \"ext1\\.\" \"INSERT INTO ${COPY_NAME}2 SELECT * FROM ${TABLE};\" -E \"SELECT ${COPY_NAME}1.data, ${COPY_NAME}2.data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME}1 ON vrpentries.inode == ${COPY_NAME}1.inode JOIN ${COPY_NAME}2 ON ${COPY_NAME}1.inode == ${COPY_NAME}2.inode; DELETE FROM ${COPY_NAME}1; DELETE FROM ${COPY_NAME}2;\" \"${INDEXROOT}\""

    echo "#####################################"
    echo

    echo "# Bad pattern"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}(data TEXT, inode TEXT);\" --external-copy \"*\" \"INSERT INTO ${COPY_NAME} SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME} ON vrpentries.inode == ${COPY_NAME}.inode;\" \"${INDEXROOT}\" 2>&1 | @GREP@ \"Error:\"" | @SED@ "s%offset [0-9]*%offset 0%g;"

    echo "# Bad SQL"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" -I \"CREATE TABLE ${COPY_NAME}(data TEXT, inode TEXT);\" --external-copy \".*\\.db\" \"INSERT INTO SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME} ON vrpentries.inode == ${COPY_NAME}.inode;\" \"${INDEXROOT}\" 2>&1 | head -n 1"

    echo "# Missing -I"
    run_sort "${GUFI_QUERY} -d \"${DELIM}\" --external-copy \".*\\.db\" \"INSERT INTO ${COPY_NAME} SELECT * FROM ${TABLE};\" -E \"SELECT data, rpath(sname, sroll, name) FROM vrpentries JOIN ${COPY_NAME} ON vrpentries.inode == ${COPY_NAME}.inode;\" \"${INDEXROOT}\""
) | replace | tee "${OUTPUT}"

@DIFF@ @CMAKE_CURRENT_BINARY_DIR@/external_copy.expected "${OUTPUT}"
rm "${OUTPUT}"
