# index with a plugin
$ gufi_dir2index --plugin "test_indexing_plugin_ops:indexing_plugin" -x "prefix" "search"
Creating GUFI tree search with 1 threads
Total Dirs:          6
Total Non-Dirs:      14

# test plugin summary output:
$ gufi_query -d " " --plugin "test_querying_plugin_ops:querying_plugin" -E "SELECT filetype, SUM(count) FROM plugin_query_view GROUP BY filetype;" "prefix" | sort -k1,1 -k2n
directory 1
directory 1
directory 1
directory 1
directory 1
directory 1
file 0
file 1
file 2
file 2
file 3
file 6

# index with two plugins
$ gufi_dir2index --plugin "test_indexing_plugin_ops:indexing_plugin" --plugin "test_indexing_plugin_ops:indexing_plugin" -x "prefix" "search"
Creating GUFI tree search with 1 threads
Total Dirs:          6
Total Non-Dirs:      14

# test plugin summary output:
$ gufi_query -d " " --plugin "test_querying_plugin_ops:querying_plugin" -E "SELECT filetype, SUM(count) FROM plugin_query_view GROUP BY filetype;" "prefix" | sort -k1,1 -k2n
directory 2
directory 2
directory 2
directory 2
directory 2
directory 2
file 0
file 2
file 4
file 4
file 6
file 12

# index with querying plugin
$ gufi_dir2index --plugin "test_querying_plugin_ops:querying_plugin" -x "prefix" "search"
Error: "querying_plugin" has bad plugin type. Expected 1. Got: 2

# query with indexing plugin
$ gufi_query -d " " --plugin "test_indexing_plugin_ops:indexing_plugin" "prefix"
Error: "indexing_plugin" has bad plugin type. Expected 2. Got: 1

# empty plugin
$ gufi_dir2index --plugin "test_indexing_plugin_ops:empty_plugin" -x "prefix" "search" 2>&1 > /dev/null | grep -oh "Could not open plugin library"
Could not open plugin library

# missing entry point
$ gufi_dir2index --plugin ":querying_plugin" -x "prefix" "search" 2>&1 | grep "Error: "
Error: Bad plugin filename

# missing file
$ gufi_dir2index --plugin "test_indexing_plugin_ops:" -x "prefix" "search" 2>&1 | grep "Error: "
Error: Bad plugin filename

# plugin file not found
$ gufi_dir2index --plugin "test_indexing_plugin_ops:run_vt.bad_ext" -x "prefix" "search" 2>&1 | grep "Error: "
Error: Could not open plugin library

# plugin entry point not found
$ gufi_dir2index --plugin "test_indexing_plugin_ops2:indexing_plugin" -x "prefix" "search" 2>&1 | grep "Error: "
Error: Could not find exported operations "test_indexing_plugin_ops2" in the plugin library

# global init error
$ gufi_query -d " " --plugin "test_querying_plugin_bad_ops:querying_plugin" -E "SELECT filetype, SUM(count) FROM plugin_query_view GROUP BY filetype;" "prefix"
Error: test_querying_plugin: Bad global initialization

