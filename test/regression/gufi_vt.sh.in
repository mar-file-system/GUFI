# "AS IS" AND ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO,
# THE IMPLIED WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE
# ARE DISCLAIMED. IN NO EVENT SHALL LOS ALAMOS NATIONAL SECURITY, LLC OR
# CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT, INCIDENTAL, SPECIAL,
# EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO, PROCUREMENT
# OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS
# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN
# CONTRACT, STRICT LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING
# IN ANY WAY OUT OF THE USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY
# OF SUCH DAMAGE.



set -e
. @CMAKE_CURRENT_BINARY_DIR@/setup.sh 1
. @CMAKE_CURRENT_BINARY_DIR@/gufi_vt.common

OUTPUT="gufi_vt.out"

PATH_LIST="path_list"
BADDIR=$(mktemp -d "${INDEXROOT}.XXXXXX")

cleanup() {
    rm -rf "${PATH_LIST}" "${BADDIR}"
}

cleanup_exit() {
    cleanup
    setup_cleanup
}

trap cleanup_exit EXIT

cleanup

query_vt() {
    gufi_vt "$@" 2>&1
}

(
echo "# ######################################"
echo "# gufi_vt_*"
run_tests query_vt

echo "# ######################################"
echo "# gufi_vt"
echo
echo "# Manipulate column without alias"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT path() || '/' || name, size FROM pentries;\");"
    echo -n "SELECT size, \"path() || '/' || name\" FROM gufi ORDER BY size ASC, \"path() || '/' || name\" ASC;"
)
query_vt "${query}"

echo "# Manipulate column with alias"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT path() || '/' || name AS fullpath, size FROM pentries;\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# S selects more columns than E - S columns get dropped and mapped incorrectly"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", S=\"SELECT * FROM summary;\", E=\"SELECT path() || '/' || name AS fullpath, size FROM pentries;\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Multiple indexes"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}/directory\", E=\"SELECT name, size, atime, mtime FROM pentries;\", '${INDEXROOT}/leaf_directory', index=\"${INDEXROOT}/directory/subdirectory\", threads=${THREADS}, n=${THREADS});"
    echo -n "SELECT size, atime, mtime, name FROM gufi ORDER BY size ASC, name ASC;"
)
query_vt "${query}"

echo "# min_level/max_level"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", S=\"SELECT path() AS fullpath, size FROM summary;\", min_level=1, max_level=1);"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# min_level/max_level + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", S=\"SELECT path() AS fullpath, size FROM summary;\", min_level=1, max_level=1, remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Run IF"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"SELECT NULL;\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\", F=\"SELECT NULL;\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Run IF with remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"SELECT NULL;\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\", F=\"SELECT NULL;\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# SELECT TSE"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", T=\"SELECT NULL;\", S=\"SELECT NULL;\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\");"
    echo -n "SELECT size, fullpath FROM gufi WHERE size IS NOT NULL ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# SELECT TSE with -a 2"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", a=2, T=\"SELECT NULL WHERE 0;\", S=\"SELECT NULL WHERE 0;\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\");"
    echo -n "SELECT size, fullpath FROM gufi WHERE size IS NOT NULL ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# SELECT TSE with -a 2 with remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", a=2, T=\"SELECT NULL WHERE 0;\", S=\"SELECT NULL WHERE 0;\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT size, fullpath FROM gufi WHERE size IS NOT NULL ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# SELECT T only"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", T=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# SELECT S only"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", S=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Aggregation"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate (fullpath TEXT, size INT64);\", E=\"INSERT INTO intermediate SELECT path() || '/' || name, size FROM pentries;\", K=\"CREATE TABLE aggregate(fullpath TEXT, size INT64);\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * FROM aggregate;\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# xattr view"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT path() || '/' || name AS fullpath, xattr_name, xattr_value FROM xpentries;\");"
    echo -n "SELECT * FROM gufi ORDER BY fullpath ASC, xattr_name ASC;"
)
query_vt "${query}"

echo "# Get source paths"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT spath(sname, sroll, name) AS srcpath, size FROM vrpentries;\", p=\"source/${SRCDIR}\");"
    echo -n "SELECT size, srcpath FROM gufi ORDER BY size ASC, srcpath ASC;"
)
query_vt "${query}"

echo "# Get source paths + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT spath(sname, sroll, name) AS srcpath, size FROM vrpentries;\", p=\"source/${SRCDIR}\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT size, srcpath FROM gufi ORDER BY size ASC, srcpath ASC;"
)
query_vt "${query}"

echo "# Run custom UDFs"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", S=\"SELECT strop('echo str') AS str, intop('echo 1') AS num, blobop('printf blob; printf 1') AS blob FROM vrsummary;\");"
    echo -n "SELECT str, num, blob FROM gufi;"
)
query_vt "${query}"

echo "# Get Row IDs"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate (fullpath TEXT);\", S=\"INSERT INTO intermediate SELECT rpath(sname, sroll) FROM vrsummary;\", K=\"CREATE TABLE aggregate(fullpath TEXT);\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * FROM aggregate ORDER BY fullpath ASC;\");"
    echo -n "SELECT rowid, * FROM gufi;"
)
query_vt "${query}"

echo "# Remote gufi_vt without aggregation"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries;\", verbose=0, remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Remote gufi_vt with min_level = 1"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;\", VERBOSE=1, min_level=1, remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Get gufi_vt from remote with a path list"
# can't use find.sh because full path is needed
run_no_sort "echo \"${INDEXROOT}/directory\" > \"${PATH_LIST}\""
run_sort "cat \"${PATH_LIST}\""
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;\", path_list=\"${PATH_LIST}\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Get gufi_vt_* from remote with a path list and min_level = 2"
run_no_sort "${FIND_SH} \"${INDEXROOT}\" 2 ${THREADS} > \"${PATH_LIST}\""
run_sort "cat \"${PATH_LIST}\""
query=$(
    echo -n "SELECT level, path || '/' || name FROM gufi_vt_pentries('${INDEXROOT}', ${THREADS}, 2, NULL, '${PATH_LIST}', 1, '${SSH_FAKE}', 'remote');"
)
query_vt "${query}"

echo "# Remote aggregate"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate (fullpath TEXT, size INT64);\", E=\"INSERT INTO intermediate SELECT path() || '/' || name, size FROM pentries;\", K=\"CREATE TABLE aggregate(fullpath TEXT, size INT64);\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * FROM aggregate;\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# Make sure all types work (have to use aggregation so that prepare doesn't treat all columns as NULL types)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate(fullpath TEXT, size INT64, size_f REAL, big_int INTEGER, name_blob BLOB);\", S=\"INSERT INTO intermediate SELECT rpath(sname, sroll) AS fullpath, size, CAST(size AS REAL), 1024 * 1024 * 1024 * 1024, CAST(rpath(sname, sroll) AS BLOB) FROM vrsummary;\", K=\"CREATE TABLE aggregate(fullpath TEXT, size INT64, size_f REAL, big_int INTEGER, name_blob BLOB);\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * from aggregate;\");"
    echo -n "SELECT * FROM gufi ORDER BY fullpath ASC;"
)
query_vt "${query}"

echo "# Force bad integer values"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate(i INTEGER);\", S=\"INSERT INTO intermediate SELECT rpath(sname, sroll) FROM vrsummary;\", K=\"CREATE TABLE aggregate(i INTEGER);\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * from aggregate;\");"
    echo -n "SELECT * FROM gufi ORDER BY i ASC;"
)
query_vt "${query}"

echo "# Force bad float values"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate(i FLOAT);\", S=\"INSERT INTO intermediate SELECT rpath(sname, sroll) FROM vrsummary;\", K=\"CREATE TABLE aggregate(i FLOAT);\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * from aggregate;\");"
    echo -n "SELECT * FROM gufi ORDER BY i ASC;"
)
query_vt "${query}"

echo "# dir_match_uid/gid without values"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", dir_match_uid=, dir_match_gid=, E=\"SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;\", verbose=1);"
    echo -n "SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# dir_match_uid/gid without values + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", dir_match_uid=, dir_match_gid=, E=\"SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;\", verbose=1, remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# dir_match_uid/gid with values"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", dir_match_uid=${USER_ID}, dir_match_gid=${GROUP_ID}, E=\"SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;\", verbose=1);"
    echo -n "SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
)
query_vt "${query}" | @SED@ "s%uid=${USER_ID}%uid=euid%g; s%gid=${GROUP_ID}%gid=egid%g;"

echo "# dir_match_uid/gid with values + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", dir_match_uid=${USER_ID}, dir_match_gid=${GROUP_ID}, E=\"SELECT rpath(sname, sroll, name) AS fullpath, level() AS level FROM vrpentries;\", verbose=1, remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT level, fullpath FROM gufi ORDER BY level ASC, fullpath ASC;"
)
query_vt "${query}" | @SED@ "s%uid=${USER_ID}%uid=euid%g; s%gid=${GROUP_ID}%gid=egid%g;"

echo "# Good Q and I but nothing actually happens (no template db is attached)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"ATTACH ':memory:' AS template; CREATE TABLE template.tablename(i INTEGER);\", E=\"SELECT name FROM vrpentries;\", Q=\"basename tablename template.tablename view\");"
    echo -n "SELECT * FROM gufi ORDER BY name;"
)
query_vt "${query}"

echo "# Good Q and I but nothing actually happens (no template db is attached) + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"ATTACH ':memory:' AS template; CREATE TABLE template.tablename(i INTEGER);\", E=\"SELECT name FROM vrpentries;\", Q=\"basename tablename template.tablename view\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT * FROM gufi ORDER BY name;"
)
query_vt "${query}"

echo "# Good external_attach and I but nothing actually happens (no template db is attached)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"ATTACH ':memory:' AS template; CREATE TABLE template.tablename(i INTEGER);\", E=\"SELECT name FROM vrpentries;\", external_attach=\"basename tablename template.tablename view\");"
    echo -n "SELECT * FROM gufi ORDER BY name;"
)
query_vt "${query}"

echo "# Good external_attach and I but nothing actually happens (no template db is attached) + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"ATTACH ':memory:' AS template; CREATE TABLE template.tablename(i INTEGER);\", E=\"SELECT name FROM vrpentries;\", external_attach=\"basename tablename template.tablename view\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT * FROM gufi ORDER BY name;"
)
query_vt "${query}"

echo "# Good external_copy and I but nothing actually happens"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE ext(i INTEGER);\", E=\"SELECT name FROM vrpentries; DELETE FROM ext;\", external_copy=\"basename 'INSERT INTO ext SELECT 0;'\");"
    echo -n "SELECT * FROM gufi ORDER BY name;"
)
query_vt "${query}"

echo "# Good external_copy and I but nothing actually happens + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE ext(i INTEGER);\", E=\"SELECT name FROM vrpentries;\", external_copy=\"basename 'INSERT INTO ext SELECT 0; DELETE FROM ext;'\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT * FROM gufi ORDER BY name;"
)
query_vt "${query}"

echo "# LIKE"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT rpath(sname, sroll, name) AS fullpath FROM vrpentries WHERE fullpath LIKE '%file%';\");"
    echo -n "SELECT * FROM gufi ORDER BY fullpath ASC;"
)
query_vt "${query}"

echo "# No results with LIKE (not an error)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT rpath(sname, sroll, name) AS fullpath FROM vrpentries WHERE fullpath LIKE '%no_match%';\");"
    echo -n "SELECT * FROM gufi ORDER BY fullpath ASC"
)
query_vt "${query}"

echo "# REGEXP"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries WHERE fullpath REGEXP '.*file.*';\");"
    echo -n "SELECT size, fullpath FROM gufi ORDER BY size ASC, fullpath ASC;"
)
query_vt "${query}"

echo "# No results with REGEXP (not an error)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT rpath(sname, sroll, name) AS fullpath, size FROM vrpentries WHERE fullpath REGEXP '.*no_match.*';\");"
    echo -n "SELECT * FROM gufi ORDER BY fullpath ASC"
)
query_vt "${query}"

echo "# ######################################"
echo "# errors"

set +e
echo "# Missing indexroot"
query_vt "SELECT name FROM gufi_vt_pentries();"

echo "# Missing indexroot"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt();"

echo "# NULL indexroot"
query_vt "SELECT name FROM gufi_vt_pentries(NULL);"

echo "# NULL indexroot"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt(E='SELECT 0;');"

(
    echo "# Empty string thread count"
    query_vt "SELECT name FROM gufi_vt_pentries('${INDEXROOT}', '') ORDER BY name ASC, size ASC;" | @SED@ '\%gufi_query:%d;'

    echo "# Zero thread count"
    query_vt "SELECT name FROM gufi_vt_pentries('${INDEXROOT}', 0) ORDER BY name ASC, size ASC;"

    echo "# Bad min_level"
    query_vt "SELECT name FROM gufi_vt_pentries('${INDEXROOT}', ${THREADS}, 'a') ORDER BY name ASC, size ASC;"

    echo "# Bad n"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', n=a, E='SELECT 0;'); SELECT * FROM gufi;"

    echo "# Zero n"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', n=0, E='SELECT 0;'); SELECT * FROM gufi;"

    echo "# NULL n"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', n=NULL, E='SELECT 0;'); SELECT * FROM gufi;"

    echo "# Bad thread count"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', threads=a, E='SELECT 0;'); SELECT * FROM gufi;"

    echo "# Zero thread count"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', threads=0, E='SELECT 0;'); SELECT * FROM gufi;"

    echo "# NULL thread count"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', threads=NULL, E='SELECT 0;'); SELECT * FROM gufi;"

    echo "# Bad a"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', a=a, E='SELECT * FROM pentries'); SELECT * FROM gufi;"

    echo "# Bad a"
    query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', a=3, E='SELECT * FROM pentries'); SELECT * FROM gufi;"
) | @SED@ 's%file descriptor [0-9]\+:%file descriptor:%g; \%^.* requires an argument%d;' # different getopt_long()s print slightly different "requires an argument" messages

echo "# Bad E"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', E='');"

echo "# Bad E"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', E='DELETE FROM entries;');"

echo "# Bad K"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', K='0', G='');"

echo "# Bad K"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', K=' ', G='');"

echo "# Bad G"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', K='CREATE TABLE aggregate(i INT);', G='SELECT * FROM intermediate');"

echo "# Missing p"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT spath(sname, sroll, name) AS srcpath, size FROM vrpentries;\");"
    echo -n "SELECT size, srcpath FROM gufi ORDER BY size ASC, srcpath ASC;"
)
echo "$ ("
echo "    echo \"${LOAD}\""
echo "    echo \"${query}\""
echo ") | ${SQLITE3}"
(
    echo "${LOAD}"
    echo "${query}"
) | PATH="@CMAKE_BINARY_DIR@/src:${PATH}" LD_PRELOAD="${ASAN_PRELOAD}:${TSAN_PRELOAD}:${LD_PRELOAD}" "${SQLITE3}" 2>&1 | sort # query_vt does not sort
echo

echo "# Bad verbose (path_list == NULL is not an error)"
query_vt "SELECT name FROM gufi_vt_pentries('${INDEXROOT}', ${THREADS}, 0, NULL, NULL, 'a') ORDER BY name ASC, size ASC;"

echo "# Bad verbose"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', verbose='a');"

echo "# Bad 1 character key"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', ?='');"

echo "# Bad 5 character key (only 'index' is recognized)"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', abcde='');"

echo "# Bad 7 character key (only 'threads' is recognized)"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', abcdefg='');"

echo "# Bad key length"
query_vt "CREATE VIRTUAL TABLE gufi USING gufi_vt('${INDEXROOT}', ab='');"

echo "# Bad plugin (using indexing plugin for querying)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", setup_res_col_type=\"CREATE TABLE plugin_query_view(filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"SELECT * FROM plugin_query_view;\", plugin=\"${TEST_INDEXING_PLUGIN_OPS}:${GUFI_INDEXING_PLUGIN}\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad plugin (plugin path is directory)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", setup_res_col_type=\"CREATE TABLE plugin_query_view(filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"SELECT * FROM plugin_query_view;\", plugin=\"${TEST_QUERYING_PLUGIN_OPS}:${INDEXROOT}\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}" | @SED@ 's%plugin library.*%plugin library%g;'

echo "# Bad plugin (global_init fails)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", setup_res_col_type=\"CREATE TABLE plugin_query_view(filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"SELECT * FROM plugin_query_view;\", plugin=\"test_querying_plugin_bad_ops:${GUFI_QUERYING_PLUGIN}\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad Q (Missing I)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT * FROM vrxpentries;\", Q=\"basename table template.table view\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad Q (not enough arguments)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"ATTACH ':memory:' AS template; CREATE TABLE template.tablename(i INTEGER);\", E=\"SELECT * FROM vrpentries;\", Q=\"basename\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad external_attach (Missing I)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT * FROM vrxpentries;\", external_attach=\"basename table template.table view\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad external_attach (not enough arguments)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"ATTACH ':memory:' AS template; CREATE TABLE template.tablename(i INTEGER);\", E=\"SELECT * FROM vrpentries;\", external_attach=\"basename\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad external_copy (Missing I)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", E=\"SELECT * FROM vrxpentries;\", external_copy=\"basename 'INSERT INTO ext SELECT 0;'\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad external_copy (no arguments)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE ext(i INTEGER);\", E=\"SELECT * FROM vrpentries;\", external_copy=\"\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad external_copy (not enough arguments)"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE ext(i INTEGER);\", E=\"SELECT * FROM vrpentries;\", external_copy=\"basename\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Bad Column Type Setup"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", setup_res_col_type=\"CREATE plugin_query_view(filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"SELECT * FROM plugin_query_view;\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"
) | replace | tee "${OUTPUT}"

# FIXME: cygwin is having trouble with plugin tests.
#        sqlite3_initialize fails without an error message.
#        Disabling sqlite3_initialize causes segfaults.

(
rm -rf "${SEARCH}"
"${GUFI_DIR2INDEX}" --plugin "${TEST_INDEXING_PLUGIN_OPS}:${GUFI_INDEXING_PLUGIN}" "${SRCDIR}" "${SEARCH}" > /dev/null

echo "# Plugin without aggregation"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", setup_res_col_type=\"CREATE TABLE plugin_test_summary (filetype TEXT PRIMARY KEY, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"SELECT * FROM plugin_query_view;\", plugin=\"${TEST_QUERYING_PLUGIN_OPS}:${GUFI_QUERYING_PLUGIN}\");"
    echo -n "SELECT * FROM gufi ORDER BY filetype ASC, count ASC;"
)
query_vt "${query}"

echo "# Plugin without aggregation + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", setup_res_col_type=\"CREATE TABLE plugin_test_summary (filetype TEXT PRIMARY KEY, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"SELECT * FROM plugin_query_view;\", plugin=\"${TEST_QUERYING_PLUGIN_OPS}:${GUFI_QUERYING_PLUGIN}\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT * FROM gufi ORDER BY filetype ASC, count ASC;"
)
query_vt "${query}"

echo "# Plugin with aggregation"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate (filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"INSERT INTO intermediate SELECT * FROM plugin_query_view;\", K=\"CREATE TABLE aggregate(filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * FROM aggregate ORDER BY filetype ASC, count ASC;\", plugin=\"${TEST_QUERYING_PLUGIN_OPS}:${GUFI_QUERYING_PLUGIN}\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"

echo "# Plugin with aggregation + remote"
query=$(
    echo -n "CREATE VIRTUAL TABLE gufi USING gufi_vt(\"${INDEXROOT}\", I=\"CREATE TABLE intermediate (filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", E=\"INSERT INTO intermediate SELECT * FROM plugin_query_view;\", K=\"CREATE TABLE aggregate(filetype TEXT, count INTEGER, CHECK (filetype IN ('file', 'directory')));\", J=\"INSERT INTO aggregate SELECT * FROM intermediate;\", G=\"SELECT * FROM aggregate ORDER BY filetype ASC, count ASC;\", plugin=\"${TEST_QUERYING_PLUGIN_OPS}:${GUFI_QUERYING_PLUGIN}\", remote_cmd=\"${SSH_FAKE}\", remote_arg=\"remote\");"
    echo -n "SELECT * FROM gufi;"
)
query_vt "${query}"
) | replace

@DIFF@ @CMAKE_CURRENT_BINARY_DIR@/gufi_vt.expected "${OUTPUT}"
rm "${OUTPUT}"
