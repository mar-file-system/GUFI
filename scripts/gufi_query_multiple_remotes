import argparse
import sqlite3
import sys

import gufi_common

SQL_FLAGS = ['I', 'T', 'S', 'E', 'K', 'J', 'G']

def build_arg_parser():
    parser = argparse.ArgumentParser('gufi_query_multiple_remotes',
                                     description='run gufi_query (via gufi_vt) across multiple remotes and join results',
                                     add_help=False)

    gufi_common.add_help_version(parser)

    # gufi_query/gufi_vt flags
    gufi_common.add_delim_flag(parser)
    parser.add_argument('-n', '--threads',
                        type=gufi_common.get_positive,
                        default=1)
    for flag in SQL_FLAGS:
        parser.add_argument('-{0}'.format(flag), type=str, metavar='SQL')
    gufi_common.add_verbose_flag(parser)

    parser.add_argument('--extra-sql',
                        type=str,
                        metavar='SQL',
                        help='add SQL to modify the final results (GROUP BY, ORDER BY, LIMIT, etc.)')

    parser.add_argument('gufi_vt',
                        type=str,
                        help='path to gufi_vt extension file')

    subparsers = parser.add_subparsers(dest='remote_type',
                                       help='method for running on remotes')

    ssh_parser = subparsers.add_parser('ssh')
    ssh_parser.add_argument('--remote-cmd',
                            type=str,
                            metavar='cmd',
                            default='ssh',
                            help='path to ssh')

    ssh_parser.add_argument('uri_index',
                            nargs='+',
                            metavar='uri index',
                            help='space separated pairs of URI and index path')

    pdsh_parser = subparsers.add_parser('pdsh')
    pdsh_parser.add_argument('--remote-cmd',
                             type=str,
                             metavar='path',
                             default='pdsh',
                             help='path to pdsh')

    pdsh_parser.add_argument('uri',
                            nargs='+',
                            help='remote URI')

    pdsh_parser.add_argument('index',
                            metavar='index',
                            help='common index path across all remotes')

    return parser

def common_vt_flags(args):
    flags = ['threads={0}'.format(args.threads)]

    for flag in SQL_FLAGS:
        if getattr(args, flag):
            flags += ['{0}=\'{1}\''.format(flag, getattr(args, flag))]

    if args.verbose:
        flags += ['verbose=1']

    return flags

# run when each invocation of gufi_vt goes to one remote
# such as with ssh
#
# this has the downside of running on remotes sequentially
# instead of in parallel (limitation of SQLite 3)
def ssh(conn, parser, args):
    if len(args.uri_index) % 2:
        parser.error('Missing index path')

    # build CREATE VIRTUAL TABLE SQL
    create_vt = 'CREATE VIRTUAL TABLE vt{0} USING gufi_vt('

    flags = common_vt_flags(args)

    # set up virtual tables
    i = 0
    for i, [uri, index] in enumerate(zip(args.uri_index[::2], args.uri_index[1::2])):
        sql = create_vt.format(i) + ', '.join(flags + [
            'index=\'{0}\''.format(index),
            'remote_cmd=\'{0}\''.format(args.remote_cmd),
            'remote_arg=\'{0}\''.format(uri)
        ]) + ');'

        conn.execute(sql)

    max_vt = i

    # create SQL to join all results into a temporary table
    combined = ' UNION ALL '.join(['SELECT * FROM vt{0}'.format(i) for i in range(max_vt + 1)])

    # add extra SQL from command line
    sql = 'SELECT * FROM ({0}) {1};'.format(combined, args.extra_sql)

    return conn.execute(sql), sql

# run gufi_vt with pdsh, which sends commands to all remotes in parallel
def pdsh(conn, _parser, args):
    # build CREATE VIRTUAL TABLE SQL
    create_vt = 'CREATE VIRTUAL TABLE vt USING gufi_vt('

    flags = common_vt_flags(args)

    # set up virtual tables
    sql = create_vt + ', '.join(flags + [
        'index=\'{0}\''.format(args.index),
        'remote_cmd=\'{0}\''.format(args.remote_cmd),
        'remote_arg=\'-R\'',
        'remote_arg=\'ssh\'',
        'remote_arg=\'-w\'',
        'remote_arg=\'{0}\''.format(','.join(args.uri)),
        'remote_arg=\'-N\'', # don't prefix lines with hostname
    ]) + ');'

    conn.execute(sql)

    # add limitations from command line
    sql = 'SELECT * FROM vt {0};'.format(args.extra_sql)

    return conn.execute(sql), sql

def run(argv, _config=None, stdout=None, stderr=None):
    parser = build_arg_parser()
    args = parser.parse_args(argv[1:])

    stdout_results = ''
    stderr_results = ''

    with sqlite3.connect(":memory:") as conn:
        conn.enable_load_extension(True)
        conn.load_extension(args.gufi_vt)
        conn.enable_load_extension(False)

        func = ssh
        if args.remote_type == 'pdsh':
            func = pdsh

        res, sql = func(conn, parser, args)

        # have to call here because gufi_vt(verbose=1) does not print
        # until SELECT is run, so this would print first if placed
        # before conn.execute()
        if args.verbose:
            verbose = 'Aggregate results with:\n    {0}\n'.format(sql)
            if stderr is None:
                print(verbose, file=sys.stderr)
            else:
                stderr_results += verbose + '\n'

        # print results
        if stdout is None:
            for row in res.fetchall():
                print(*row, sep=args.delim)
        else:
            for row in res.fetchall():
                stdout_results += args.delim.join(row)

    return 0, stdout_results, stderr_results

if __name__ == '__main__':
    sys.exit(run(sys.argv)[0])
